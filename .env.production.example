# VPS production — copy to .env on the server
# Generate AUTH_SECRET: openssl rand -base64 32

DATABASE_URL="mysql://qualilab_user:STRONG_PASSWORD@localhost:3306/qualilab_proto"
AUTH_SECRET="replace-with-openssl-rand-base64-32"
NODE_ENV=production
PORT=3000

# Set to false only when testing over plain HTTP (use HTTPS in production)
# AUTH_COOKIE_SECURE=false
